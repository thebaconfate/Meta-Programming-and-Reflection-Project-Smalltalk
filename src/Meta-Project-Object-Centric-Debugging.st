Object subclass: #ObjectBreaker	instanceVariableNames: 'targetObject anonymousClass links'	classVariableNames: ''	package: 'Meta-Project-Object-Centric-Debugging'!!ObjectBreaker methodsFor: 'as yet unclassified' stamp: '5/4/2026 22:23'!onMessageSend| methods | methods := anonymousClass superclass methods. self checkSuperSends: methods. links := methods collect: [ :method |	| link |	anonymousClass compile: method sourceCode.	link := self newLink.	(anonymousClass >> method selector) ast sendNodes do: [ :node |		node link: link		 ].	link.	]. ^ self! !!ObjectBreaker methodsFor: 'as yet unclassified' stamp: '5/4/2026 22:24'!onMessageSendIn: aSelector| method link| method := (anonymousClass superclass) >> aSelector. self checkSuperSends: { method }. anonymousClass compile: method sourceCode. link := self newLink. (anonymousClass >> aSelector) ast sendNodes do: [ :node | node link: link ]. links := { link }.^ self! !!ObjectBreaker methodsFor: 'as yet unclassified' stamp: '5/5/2026 16:04'!onMessageSendIn: aSelector when: condition| method link| method := (anonymousClass superclass) >> aSelector. self checkSuperSends: { method }. anonymousClass compile: method sourceCode. link := self newLink. (anonymousClass >> aSelector) ast sendNodes do: [ :node | (condition value: node) ifTrue: [ node link: link ]]. links := { link }.^ self! !!ObjectBreaker methodsFor: 'as yet unclassified' stamp: '5/3/2026 23:15'!checkSuperSends: methods methods do: [ :method | 	method ast nodesDo: [ :node |		(node isMessage and: [ node isSuperSend])			 ifTrue: [ ObjectCentricDebuggingDoesNotSupportSuperSends signal ]		 ].	].! !!ObjectBreaker methodsFor: 'accessing' stamp: '5/3/2026 22:35'!clear links do: [ :link |	link uninstall	 ]. links := #(). ^ self! !!ObjectBreaker methodsFor: 'accessing' stamp: '5/3/2026 18:05'!links^ links.! !!ObjectBreaker methodsFor: 'initialization' stamp: '5/3/2026 22:19'!initializeWith: anObject targetObject := anObject. anonymousClass := targetObject class newAnonymousSubclass. anonymousClass adoptInstance: targetObject. links := #(). ^ self! !!ObjectBreaker methodsFor: 'instance creation' stamp: '5/5/2026 15:38'!newLink^ MetaLink new		metaObject: Break;		selector: #now; 		control: #before.! !"-- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- "!ObjectBreaker class	instanceVariableNames: ''!!ObjectBreaker class methodsFor: 'instance creation' stamp: '4/29/2026 04:52'!for: anObject ^ self new initializeWith: anObject! !TestCase subclass: #ObjectBreakerTest	instanceVariableNames: 'human objectBreaker'	classVariableNames: ''	package: 'Meta-Project-Object-Centric-Debugging'!!ObjectBreakerTest methodsFor: 'running' stamp: '5/5/2026 16:21'!setUp	super setUp.	"Put here a common initialization logic for tests"	human := Human new.	objectBreaker := ObjectBreaker for: human.! !!ObjectBreakerTest methodsFor: 'tests' stamp: '5/5/2026 16:35'!testObjectBreakerForObjectWithSuperSendRaisesError |humanWithSuperSend |  humanWithSuperSend := HumanWithSuperSend new.  objectBreaker := ObjectBreaker for: humanWithSuperSend.  self should: [ 	objectBreaker onMessageSend. 	humanWithSuperSend greet.	 ] raise: ObjectCentricDebuggingDoesNotSupportSuperSends.  objectBreaker clear.  self should: [ 	objectBreaker onMessageSendIn: #greet.	humanWithSuperSend greet.	 ] raise: ObjectCentricDebuggingDoesNotSupportSuperSends.objectBreaker clear.   self should: [ 	objectBreaker onMessageSendIn: #greet when: [ :send | send selector = #, ] ] raise: ObjectCentricDebuggingDoesNotSupportSuperSends.! !!ObjectBreakerTest methodsFor: 'tests' stamp: '5/5/2026 16:41'!testClear. "A better test would be to check if the installed metalinks are uninstalled.However, making the assumption that links is an array of active metalinks on the object we can just check it's size." objectBreaker onMessageSend. objectBreaker clear.  self assert: (objectBreaker links size = 0)! !!ObjectBreakerTest methodsFor: 'tests' stamp: '5/5/2026 16:44'!testOnMessageSend"The debugger should open twice in this test" |human2| human2 := Human new. objectBreaker onMessageSend. human greet. "This should open the debugger" human name. "This should open the debugger" human2 greet. "This should NOT open the debugger"! !!ObjectBreakerTest methodsFor: 'tests' stamp: '5/5/2026 16:45'!testOnMessageSendIn objectBreaker onMessageSendIn: #greet. human greet. "This should open the debugger" human name. "This should NOT open the debugger"! !!ObjectBreakerTest methodsFor: 'tests' stamp: '5/5/2026 16:46'!testOnMessageSendInWhen objectBreaker onMessageSendIn: #greet when: [:send | send selector = #,]. human greet. "This should open the debugger" objectBreaker clear. objectBreaker onMessageSendIn: #greet when: [:send | send selector = #+]. human greet. "This should NOT open the debugger"! !Object subclass: #Human	instanceVariableNames: 'name'	classVariableNames: ''	package: 'Meta-Project-Object-Centric-Debugging'!!Human methodsFor: 'as yet unclassified' stamp: '5/4/2026 18:44'!greet^ 'Hello my name is ', self name! !!Human methodsFor: 'initialization' stamp: '5/2/2026 05:53'!initializename := 'Albert Einstein'.^self.! !!Human methodsFor: 'accessing' stamp: '5/2/2026 05:53'!name: aNamename := aName.self! !!Human methodsFor: 'accessing' stamp: '5/2/2026 05:53'!name^ name ! !Human subclass: #HumanWithSuperSend	instanceVariableNames: ''	classVariableNames: ''	package: 'Meta-Project-Object-Centric-Debugging'!!HumanWithSuperSend methodsFor: 'as yet unclassified' stamp: '5/5/2026 16:19'!greet 	^ super greet! !Error subclass: #ObjectCentricDebuggingDoesNotSupportSuperSends	instanceVariableNames: ''	classVariableNames: ''	package: 'Meta-Project-Object-Centric-Debugging'!