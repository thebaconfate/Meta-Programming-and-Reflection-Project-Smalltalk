'>	^self classLayout visibleSlots! !!ClassDescription methodsFor: 'queries - protocols' stamp: 'nil'!ensureProtocol: aProtocol	"I can take a Protocol or a protocol name as paramater.		If my parameter is a name, I'll return a protocol associated with it. A new one if needed.	If my parameter is a Protocol, I'll return it if it comes from me or I'll create one of the same name."	aProtocol ifNil: [ ^ self ensureProtocol: Protocol unclassified ].	^ self addProtocol: aProtocol! !!ClassDescription methodsFor: 'accessing - packages' stamp: 'nil'!extendingPackages	"the extending packages of a class are the packages that extend it."	^ (self localMethods , self classSide localMethods		   select: [ :each | each isExtension ]		   thenCollect: [ :each | each extensionPackage ]) asIdentitySet! !!ClassDescription methodsFor: 'accessing - packages' stamp: 'nil'!extensionSelectors	^ self extendingPackages flatCollect: [ :each | each extensionSelectorsForClass: self ]! !!ClassDescription methodsFor: 'accessing - packages' stamp: 'nil'!package: aPackage	^ (self packageOrganizer ensurePackage: aPackage) addClass: self! !!ClassDescription methodsFor: 'accessing - packages' stamp: 'nil'!package: aPackage tag: aTag	^ (self packageOrganizer ensureTag: aTag inPackage: aPackage) addClass: self! !!ClassDescription methodsFor: 'accessing - packages' stamp: 'nil'!packageName	^ self package ifNotNil: [ :package | package name ]! !!ClassDescription methodsFor: 'accessing - packages' stamp: 'nil'!packageTag: aTag	(aTag isString ifTrue: [ self package ensureTag: aTag ] ifFalse: [ aTag ]) addClass: self! !!ClassDescription methodsFor: 'accessing - packages' stamp: 'nil'!packageTagName	"Package tags are sub categories of packages to have a better organization of the packages. I return the name of my package tag.."	^ self packageTag name! !!ClassDescription methodsFor: 'accessing - packages' stamp: 'nil'!packages	"the extending packages of a class are the packages that extend it."	^ self extendingPackages		  add: self package;		  yourself! !!ClassDescription methodsFor: 'accessing - packages' stamp: 'nil'!removePackageTag	"Removing a package tag is the same as moving it to the root tag that is the uncategorized tag."	| package |	package := self package.	package moveClass: self toTag: package rootTag! !!ClassDescription methodsFor: 'initialization' stamp: 'nil'!initialize	super initialize.	self resetProtocols! !!ClassDescription methodsFor: 'initialization' stamp: 'nil'!obsolete	"Make the receiver obsolete."	self superclass removeSubclass: self.	super obsolete! !!ClassDescription methodsFor: 'initialization' stamp: 'nil'!superclass: aSuperclass layout: aLayout	layout := aLayout.	self		superclass: aSuperclass		methodDictionary: self emptyMethodDictionary		format: aLayout format! !!ClassDescription methodsFor: 'initialization' stamp: 'nil'!superclass: aClass methodDictionary: mDict format: fmt	"Basic initialization of the receiver"	super superclass: aClass methodDictionary: mDict format: fmt.	self resetProtocols! !!ClassDescription methodsFor: 'initialization' stamp: 'nil'!superclass: aSuperclass withLayoutType: layoutType slots: slotArray	| superLayout newScope newLayout |	superLayout := aSuperclass						ifNil: [ EmptyLayout instance ]						ifNotNil: [ aSuperclass classLayout ].	newScope := superLayout slotScope extend: slotArray.	newLayout := layoutType extending: superLayout scope: newScope host: self.	newLayout checkSanity.	self		superclass: aSuperclass		layout: newLayout! !!ClassDescription methodsFor: 'private' stamp: 'nil'!instVarMappingFrom: oldClass	"Return the mapping from instVars of oldClass to new class that is used for converting old instances of oldClass."	| oldInstVarNames |	oldInstVarNames := oldClass allInstVarNames.	^self allInstVarNames			collect: [:instVarName | oldInstVarNames indexOf: instVarName]! !!ClassDescription methodsFor: 'private' stamp: 'nil'!isProtocolExtensionFromTheSamePackage: aProtocol	"I return true if the protocol as parameter is an extension protocol and the concerned package is my origin package."	| protocolName |	aProtocol ifNil: [ ^ false ].	protocolName := aProtocol isString		                ifTrue: [ aProtocol ]		                ifFalse: [ aProtocol name ].	"If it is not an extension then there is no problem"	protocolName first = $* ifFalse: [ ^ false ].	^ (self packageOrganizer packageMatchingExtensionName: protocolName allButFirst) = self package! !!ClassDescription methodsFor: 'private' stamp: 'nil'!linesOfCode	"An approximate measure of lines of code.	Includes comments, but excludes blank lines."	| lines |	lines := self localMethods inject: 0 into: [ :sum :each | sum + each linesOfCode ].	^ self isMeta		ifTrue: [ lines ]		ifFalse: [ lines + self classSide linesOfCode ]! !!ClassDescription methodsFor: 'private' stamp: 'nil'!newInstanceFrom: oldInstance variable: variable size: instSize	"Create a new instance of the receiver based on the given old instance.	The supplied map contains a mapping of the old instVar names into	the receiver's instVars"	| new  value |	variable		ifTrue: [ new := self basicNew: oldInstance basicSize ]		ifFalse: [ new := self basicNew ].	"Slot migration happens there"	self allSlots		do: [ :newSlot |			oldInstance class				slotNamed: newSlot name				ifFound: [ :oldSlot |					newSlot wantsInitialization ifTrue: [ self initializeSlots: new ].					value := oldSlot read: oldInstance.					newSlot write: value to: new ] ].	variable		ifTrue: [ 1 to: oldInstance basicSize do: [ :offset | new basicAt: offset put: (oldInstance basicAt: offset) ] ].	^ new! !!ClassDescription methodsFor: 'private' stamp: 'nil'!numberOfMethods	"count all methods that are local (not comming from a trait)"	| num |	num := self localMethods size.	^ self isMeta		ifTrue: [ num ]		ifFalse: [ num + self classSide numberOfMethods ]! !!ClassDescription methodsFor: 'private' stamp: 'nil'!spaceUsed	^super spaceUsed + (self hasClassSide		ifTrue: [self classSide spaceUsed]		ifFalse: [0])! !!ClassDescription methodsFor: 'testing' stamp: 'nil'!isDeprecated	^ self package isDeprecated! !!ClassDescription methodsFor: 'testing' stamp: 'nil'!isExtended	^ self extendingPackages isEmpty! !!ClassDescription methodsFor: 'testing' stamp: 'nil'!isExtendedInPackage: aPackage	"returns true if aPackage defines an extension to this class"	^ aPackage extendsClass: self! !!ClassDescription methodsFor: 'testing' stamp: 'nil'!isInstalled	"Return true if I am installed in the system (which is equivalent to me been part of my package organizer). Else, return false."	^ self packageOrganizer isClassInstalled: self! !!ClassDescription methodsFor: 'testing' stamp: 'nil'!isLocalSelector: aSelector	<reflection: 'Class structural inspection - Selectors and methods inspection'>	^ self methodDict includesKey: aSelector! !!ClassDescription methodsFor: 'testing' stamp: 'nil'!isTaggedWith: aSymbol	^ self packageTagName		  ifNil: [ false ]		  ifNotNil: [ :tag | tag = aSymbol ]! !!ClassDescription methodsFor: 'accessing - deprecated parallel hierarchy' stamp: 'nil'!isMeta	<reflection: 'Class structural inspection - Class kind testing'>	^self isClassSide! !!ClassDescription methodsFor: 'organization updating' stamp: 'nil'!notifyOfRecategorizedSelector: selector from: oldProtocol to: newProtocol	"If compiled method is not there, it meens it has been removed, not recategorized... so I skip	 the method recategorized announce"	self compiledMethodAt: selector ifPresent: [ :method | self announceRecategorizationOf: method oldProtocol: oldProtocol ]! !!ClassDescription methodsFor: 'organization' stamp: 'nil'!reorganize	"During fileIn, !!Rectangle reorganize!! allows Rectangle to seize control and treat the next chunk as its organization.  See the transfer of control where ReadWriteStream fileIn calls scanFrom:"	^ self! !!ClassDescription methodsFor: 'storing' stamp: 'nil'!storeOn: aStream	"Classes and Metaclasses have global names."	aStream nextPutAll: self name! !!ClassDescription methodsFor: 'queries' stamp: 'nil'!whichMethodsAccess: instVarName	"Answer the methods that access the argument, instVarName, as a named instance variable. Pay attention the instVarName variable should be used e.g., be part of a return, message send or assignment else the compiler optimize it away and the method will not return it."	^ self		slotNamed: instVarName		ifFound: [ :slot | self methods select: [ :m | slot isAccessedIn: m ] ]		ifNone: [ #() ]! !!ClassDescription methodsFor: 'queries' stamp: 'nil'!whichMethodsRead: instVarName	"Answer the selectors whose methods read the argument, instVarName, as a named instance variable.	Pay attention the instVarName variable should be used e.g., be part of a return, message send or assignment else the compiler optimize it away and the method will not return it."	^ self		slotNamed: instVarName		ifFound: [ :slot | self methods select: [ :m | slot isReadIn: m ] ]		ifNone: [ #() ]! !!ClassDescription methodsFor: 'queries' stamp: 'nil'!whichMethodsWrite: instVarName	"Answer the selectors whose methods write the argument, instVarName, as a named instance variable.	Pay attention the instVarName variable should be used e.g., be part of a return, message send or assignment else the compiler optimize it away and the method will not return it."	^ self		slotNamed: instVarName		ifFound: [ :slot | self methods select: [ :m | slot isWrittenIn: m ] ]		ifNone: [ #() ]! !!ClassDescription methodsFor: 'queries' stamp: 'nil'!whichSelectorsAccess: instVarName	"Answer the selectors whose methods access the argument, instVarName, as a named instance variable. Pay attention the instVarName variable should be used e.g., be part of a return, message send or assignment else the compiler optimize it away and the method will not return it."	^ self		slotNamed: instVarName		ifFound: [ :slot | self selectors select: [ :sel | slot isAccessedIn: self>>sel ] ]		ifNone: [ #() ]! !!ClassDescription methodsFor: 'queries' stamp: 'nil'!whichSelectorsRead: instVarName	"Answer the selectors whose methods read the argument, instVarName, as a named instance variable.	Pay attention the instVarName variable should be used e.g., be part of a return, message send or assignment else the compiler optimize it away and the method will not return it."	^ self		slotNamed: instVarName		ifFound: [ :slot | self selectors select: [ :sel | slot isReadIn: self >> sel ] ]		ifNone: [ #() ]! !!ClassDescription methodsFor: 'queries' stamp: 'nil'!whichSelectorsWrite: instVarName	"Answer the selectors whose methods write the argument, instVarName, as a named instance variable.	Pay attention the instVarName variable should be used e.g., be part of a return, message send or assignment else the compiler optimize it away and the method will not return it."	^ self		slotNamed: instVarName		ifFound: [ :slot | self selectors select: [ :sel | slot isWrittenIn: self >> sel ] ]		ifNone: [ #() ]! !!ClassDescription methodsFor: '*System-Sources' stamp: '2/6/2026 15:56'!printProtocolChunk: protocol on: aFileStream withStamp: changeStamp priorMethod: priorMethod	"Print a method preamble.  This must have a protocol name.	It may have an author/date stamp, and it may have a prior source link.	If it has a prior source link, it MUST have a stamp, even if it is empty."	"The current design is that changeStamps and prior source links are preserved in the changes file.  All fileOuts include changeStamps.  Condensing sources, however, eliminates all stamps (and links, natch)."	aFileStream		cr;		nextPut: $!!.	aFileStream nextChunkPut: (String streamContents: [ :strm |			 strm				 nextPutAll: self name;				 nextPutAll: ' methodsFor: ';				 print: (protocol ifNotNil: [							  protocol isString								  ifTrue: [ protocol ]								  ifFalse: [ protocol name ] ]) asString.			 (changeStamp isNotNil and: [ changeStamp size > 0 or: [ priorMethod isNotNil ] ]) ifTrue: [				 strm					 nextPutAll: ' stamp: ';					 print: changeStamp ].			 priorMethod ifNotNil: [				 strm					 nextPutAll: ' prior: ';					 print: priorMethod sourcePointer ] ])! !!ClassDescription methodsFor: '*System-Support' stamp: '2/6/2026 15:56'!allCallsOnIn: aSystemNavigation	"Answer a SortedCollection of all the methods that refer to me by name or as part of an association in a global dict."	^ (aSystemNavigation allReferencesTo: (self environment associationAt: self instanceSide name))  	        , (aSystemNavigation allCallsOn: self instanceSide name)! !!ClassDescription methodsFor: '*Traits' stamp: '2/6/2026 15:56'!addToComposition: aTrait	self setTraitComposition: self traitComposition + aTrait! !!ClassDescription methodsFor: '*Traits' stamp: '2/6/2026 15:56'!selectorsWithExplicitOrigin	^self traitComposition selectors , self localSelectors! !!ClassDescription methodsFor: '*Traits' stamp: '2/6/2026 15:56'!asTraitComposition	^ TaCompositionElement for: self! !!ClassDescription methodsFor: '*Traits' stamp: '2/6/2026 15:56'!baseComposition	^ TaEmptyComposition new! !!ClassDescription methodsFor: '*Traits' stamp: '2/6/2026 15:56'!traitComposition	^ TaEmptyComposition new! !!ClassDescription methodsFor: '*Monticello' stamp: 'nil'!mcWorkingCopy	^ self package mcWorkingCopy! !!ClassDescription methodsFor: '*STON-Core' stamp: '2/6/2026 15:56'!stonContainSubObjects	^ false! !!ClassDescription methodsFor: '*SUnit-Core' stamp: '2/6/2026 15:56'!isTestCase	^false! !!ClassDescription methodsFor: '*Fuel-Core' stamp: '2/6/2026 15:57'!fuelRecomputeSlotScopeWithTraits	"We only know about trait variables once the trait composition	has been fully materialized. Now we need to update the slot scope	with the information from traits and recompute the class	format since it may currently define too many fields.	If that is indeed the case, then existing instances will have been	allocated with more fields than necessary, however, their layout	definition defines fewer slots, so all operations on instance	variables are safe.	New instances will be created with the correct amount of fields	allocated.		Note that the format computed here only differs from the initially	set format if variables were removed from the class.		See FLBehaviorCluster>>installLayout:withFormat:variableNames:into:	and FLVariablesMapping>>materializeTraitVariablesWith:."	| classSlots traitSlots newSlotScope |	(self traitComposition slots allSatisfy: [ :slot |		self hasSlotNamed: slot name ]) ifTrue: [ ^ self ].	classSlots := self classLayout slots.	traitSlots := self traitComposition slots select: [ :traitSlot |		classSlots noneSatisfy: [ :slot | slot name = traitSlot name ] ].	newSlotScope := self classLayout slotScope parentScope extend: classSlots, traitSlots.	self classLayout slotScope: newSlotScope.	self setFormat: self classLayout format! !!ClassDescription methodsFor: '*Fuel-Core' stamp: '2/6/2026 15:57'!instanceVariableNamesDo: anUnaryBlock	"This is part of the interface between the compiler and a class's instance or field names.	 The class should enumerate anUnaryBlock with the instance variable name strings.  The order is important. Names evaluated later will override the	 same names occurring earlier."	<reflection: 'Class structural inspection - Instance variable inspection'>	| superInstSize |	superInstSize := self superclass		ifNotNil: [ self superclass instSize ]      ifNil: [ 0 ].	superInstSize > 0 ifTrue: [		self superclass instanceVariableNamesDo: anUnaryBlock ].		1		to: self instSize - superInstSize		do: [ :i |			anUnaryBlock value: (self instVarNames at: i) ]! !!ClassDescription methodsFor: '*Reflectivity' stamp: '2/6/2026 15:57'!assignmentNodes	^self methods flatCollect: [ :each | each assignmentNodes ]! !!ClassDescription methodsFor: '*Reflectivity' stamp: '2/6/2026 15:57'!blockNodes	^self methods flatCollect: [ :each | each blockNodes ]! !!ClassDescription methodsFor: '*Reflectivity' stamp: '2/6/2026 15:57'!instanceVariableReadNodes	^self methods flatCollect: [ :each | each instanceVariableReadNodes ]! !!ClassDescription methodsFor: '*Reflectivity' stamp: '2/6/2026 15:57'!instanceVariableWriteNodes	^self methods flatCollect: [ :each | each instanceVariableWriteNodes ]! !!ClassDescription methodsFor: '*Reflectivity' stamp: '2/6/2026 15:57'!link: aMetaLink toAST: aNode	aNode link: aMetaLink! !!ClassDescription methodsFor: '*Reflectivity' stamp: '2/6/2026 15:57'!sendNodes	^self methods flatCollect: [ :each | each sendNodes ]! !!ClassDescription methodsFor: '*Reflectivity' stamp: '2/6/2026 15:57'!variableNodes	^self methods flatCollect: [ :each | each variableNodes ]! !!ClassDescription methodsFor: '*Reflectivity' stamp: '2/6/2026 15:57'!variableReadNodes	^self methods flatCollect: [ :each | each variableReadNodes ]! !!ClassDescription methodsFor: '*Reflectivity' stamp: '2/6/2026 15:57'!variableWriteNodes	^self methods flatCollect: [ :each | each variableWriteNodes ]! !!ClassDescription methodsFor: '*Tool-Finder' stamp: '2/6/2026 15:57'!allSelectorsToTestInMethodFinder	"Returns all the selectors that the class approved, so which can be tested by the MethodFinder without problem. This set is the set of selectors that the class approved plus all the selectors approved by its superclass unless if they are forbidden by the class."	^ (self approvedSelectorsForMethodFinder union: self superclass allSelectorsToTestInMethodFinder)			difference: self forbiddenSelectorsForMethodFinder asSet! !!ClassDescription methodsFor: '*Tool-Finder' stamp: '2/6/2026 15:57'!allSelectorsToTestInMethodFinderWithArity: anInteger	"Returns all the selectors with a certain arity which are approved by the class so whi