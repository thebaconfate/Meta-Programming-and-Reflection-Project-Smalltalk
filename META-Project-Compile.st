 unclassified' stamp: '4/9/2026 03:29'!mangle: aSelector	^ ('__', aSelector) asSymbol.! !!MangleSelfOrSuperSendsPlugin methodsFor: 'testing' stamp: '4/9/2026 03:31'!isMangled: aSelector	^ aSelector asString beginsWith: '__'! !