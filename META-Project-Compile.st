orWithSelfSend .Object removeSelector: selectorWithSelfSend asSymbol.! !!MangleSelfOrSuperSendsPluginTest methodsFor: 'tests' stamp: '4/11/2026 05:22'!testMangledSelfSendNotExists"This test tests wether or not self sends are properly mangled, in this case we don't install a method prior to installing a self send method."|selectorWithSelfSend protectedSelectorWithSelfSend method|selectorWithSelfSend := 'testSelfSendMethod'.protectedSelectorWithSelfSend := ('__', selectorWithSelfSend ) asSymbol.Object removeSelector: protectedSelectorWithSelfSend .Object removeSelector: selectorWithSelfSend asSymbol.Object compiler addPlugin: MangleSelfOrSuperSendsPlugin new;addPlugin: MangleProtectedMethodsPlugin new; source: (selectorWithSelfSend, '^ self methodDict');install.method := Object >> (selectorWithSelfSend asSymbol).self assert: (method literals includes: #methodDict).Object removeSelector: protectedSelectorWithSelfSend .Object removeSelector: selectorWithSelfSend asSymbol.! !!MangleSelfOrSuperSendsPluginTest methodsFor: 'tests' stamp: '4/20/2026 13:14'!testMangledSuperSendNotExists"This test tests wether or not super sends are properly mangled, in this case we don't install a method prior to installing a self send method.""NOTE: This test has been delegated to the AnimalCowTests"! !!MangleSelfOrSuperSendsPluginTest methodsFor: 'tests' stamp: '4/20/2026 13:14'!testMangledSuperSendExists"This test tests wether or not super sends are properly mangled, in this case we install a method prior to installing a self send method.""NOTE: This test has been delegated to the AnimalCowTests"	! !OCStaticASTCompilerPlugin subclass: #MangleProtectedMethodsPlugin	instanceVariableNames: ''	classVariableNames: ''	package: 'META-Project-Compile'!!MangleProtectedMethodsPlugin methodsFor: 'private - transforming' stamp: '4/9/2026 04:48'!transform	self isProtected ifTrue: [ 		ast selector: (self mangle: ast selector)		 ].	^ ast! !!MangleProtectedM